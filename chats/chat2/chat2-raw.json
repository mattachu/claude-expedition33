      {
        "type": "knowledge",
        "title": "Claude Code Token Limits: A Guide for Engineering Leaders | Faros AI",
        "url": "https://www.faros.ai/blog/claude-code-token-limits",
        "metadata": {
          "type": "webpage_metadata",
          "site_domain": "faros.ai",
          "favicon_url": "https://www.google.com/s2/favicons?sz=64&domain=faros.ai",
