        "url": "https://ethugamer.com/clair-obscur-expedition-33/lune-build-guide-best-weapons-attributes-skills-in-clair-obscur-expedition-33/",
        "metadata": {
          "type": "webpage_metadata",
          "site_domain": "ethugamer.com",
