      {
        "type": "knowledge",
        "title": "Clair Obscur: Expedition 33 \u2013 Best Sciel Build",
        "url": "https://game-rezone.com/en/guide/clair-obscur-expedition-33-best-sciel-build/",
        "metadata": {
          "type": "webpage_metadata",
          "site_domain": "game-rezone.com",
